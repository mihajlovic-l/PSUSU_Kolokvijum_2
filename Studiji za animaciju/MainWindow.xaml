<Window x:Class="Studiji_za_animaciju.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Studiji_za_animaciju"
        xmlns:vm="clr-namespace:Studiji_za_animaciju.ViewModels"
        mc:Ignorable="d"
        Title="Studios and Shows" Height="500" Width="900">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="Studios" Grid.Column="0" Margin="4">
            <DockPanel>
                <ToolBar DockPanel.Dock="Top">
                    <Button Content="Add" Command="{Binding AddStudioCommand}" />
                    <Button Content="Edit" Command="{Binding EditStudioCommand}" />
                    <Button Content="Delete" Command="{Binding DeleteStudioCommand}" />
                </ToolBar>
                <DataGrid ItemsSource="{Binding Studios}" SelectedItem="{Binding SelectedStudio}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <GroupBox Header="Shows" Grid.Column="1" Margin="4">
            <DockPanel>
                <ToolBar DockPanel.Dock="Top">
                    <Button Content="Add" Command="{Binding AddShowCommand}" />
                    <Button Content="Edit" Command="{Binding EditShowCommand}" />
                    <Button Content="Delete" Command="{Binding DeleteShowCommand}" />
                </ToolBar>
                <DataGrid ItemsSource="{Binding Shows}" SelectedItem="{Binding SelectedShow}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="80" />
                        <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>
    </Grid>
</Window>
